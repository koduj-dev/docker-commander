# Docker Commander configuration (environment variables).
#
# Docker Commander reads its configuration from flags OR these environment
# variables. It does NOT auto-load this file; use it with your process manager:
#
#   • systemd:   EnvironmentFile=/etc/dockercmd/dockercmd.env  (see deploy/)
#   • shell:     set -a; . ./.env; set +a; ./dockercmd
#   • docker:    docker run --env-file .env …
#
# All keys are optional — defaults are shown.

# Listen host + port. Keep the host on loopback behind a TLS reverse proxy;
# use 0.0.0.0 for all interfaces. (DC_ADDR=host:port still works and overrides.)
DC_HOST=127.0.0.1
DC_PORT=8080

# Where the SQLite DB + signing/encryption keys live (default: OS config dir).
DC_DATA_DIR=/var/lib/dockercmd

# Protect the Prometheus /metrics endpoint with a bearer token (default: open).
# DC_METRICS_TOKEN=change-me

# Store metric history in Redis instead of an in-memory ring buffer.
# DC_REDIS_ADDR=127.0.0.1:6379
# DC_REDIS_PASSWORD=
# DC_REDIS_DB=0
# DC_METRICS_RETENTION=24h

# Talk to a non-default Docker daemon (standard Docker env vars are honoured).
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_CERT_PATH=
