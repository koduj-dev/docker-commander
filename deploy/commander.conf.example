# Docker Commander config file — the canonical list of settings.
#
# Default location: /etc/docker-commander/commander.conf (Linux),
#                   %ProgramData%\docker-commander\commander.conf (Windows).
# Override the path with `-config /path/to/file` or the DC_CONFIG env var.
#
# Format: KEY=VALUE, one per line; "#" starts a comment. These are the same
# DC_* keys you can also pass as environment variables or flags.
# Precedence: command-line flag > environment variable > this file.
# All keys are optional — defaults are shown.

# Listen host + port. Behind a TLS reverse proxy, keep the host on loopback;
# use 0.0.0.0 to listen on all interfaces.
DC_HOST=127.0.0.1
DC_PORT=8080

# DC_ADDR (full host:port) is still accepted and overrides DC_HOST/DC_PORT, for
# compatibility with older setups:
# DC_ADDR=127.0.0.1:8080

# Where the SQLite DB + signing/encryption keys live.
DC_DATA_DIR=/var/lib/dockercmd

# Session token lifetime is set with the -session-ttl flag (e.g. -session-ttl 8h).

# Optional: protect the Prometheus /metrics endpoint with a bearer token.
# DC_METRICS_TOKEN=change-me

# Optional: store metric history in Redis instead of an in-memory ring buffer.
# DC_REDIS_ADDR=127.0.0.1:6379
# DC_REDIS_PASSWORD=
# DC_REDIS_DB=0
# DC_METRICS_RETENTION=24h

# Talk to a non-default Docker daemon (standard Docker env vars are honoured).
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_CERT_PATH=
